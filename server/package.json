{
  "name": "blog-server",
  "version": "1.0.0",
  "description": "中文个人博客网站 - 后端服务",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.js --platform=node --packages=external --bundle --outfile=dist/index.js",
    "start": "node dist/index.js",
    "lint": "eslint server/**/*.js",
    "test": "jest",
    "migrate": "node database/migrate.js"
  },
  "keywords": [
    "blog",
    "express",
    "nodejs"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^2.29.3",
    "dotenv": "^16.0.0",
    "express": "^4.19.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "sequelize": "^6.33.0",
    "sqlite3": "^5.1.6",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.1.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.19.0",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.0.0",
    "typescript": "^5.1.6",
    "vite": "^4.4.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "package.json"
  ]
}
